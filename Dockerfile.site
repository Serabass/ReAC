# Static KB site: run `reac export-html` then serve with nginx.
# Build: docker build -f Dockerfile.site -t reac-site .
# Run:  docker run --rm -p 8080:80 reac-site

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY project.toml ./
COPY src/Reac/Reac.csproj ./src/Reac/
RUN dotnet restore src/Reac/Reac.csproj

COPY src/ ./src/
COPY re/ ./re/

RUN dotnet run --project src/Reac/Reac.csproj -c Release -- export-html -p /src

########################################################################################

FROM nginx:1.29.7-alpine
COPY --from=build /src/re/generated/html /usr/share/nginx/html
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
