<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script>
(function(){try{var k='reac-theme',v=localStorage.getItem(k)||'system',d=v==='dark'||(v==='system'&&window.matchMedia('(prefers-color-scheme:dark)').matches);document.documentElement.setAttribute('data-theme',d?'dark':'light');}catch(e){}})();
</script>
<title>{{ title | html.escape }}</title>
{{ styles }}
</head>
<body>
<div class="theme-switcher" role="group" aria-label="Color theme">
<label class="theme-switcher-label" for="reac-theme-select">Theme</label>
<select id="reac-theme-select" class="theme-switcher-select" autocomplete="off">
<option value="system">System</option>
<option value="light">Light</option>
<option value="dark">Dark</option>
</select>
</div>
<div class="layout">
{{ sidebar }}
{{ main }}
</div>
<script>
(function(){
var sel=document.getElementById('reac-theme-select');
var k='reac-theme';
function resolve(v){
if(v==='dark')return 'dark';
if(v==='light')return 'light';
return window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
}
function applyStored(){
var v=localStorage.getItem(k)||'system';
if(sel)sel.value=v;
document.documentElement.setAttribute('data-theme',resolve(v));
}
try{
if(sel){
var cur=localStorage.getItem(k)||'system';
sel.value=cur;
sel.addEventListener('change',function(){
localStorage.setItem(k,sel.value);
document.documentElement.setAttribute('data-theme',resolve(sel.value));
});
}
window.matchMedia('(prefers-color-scheme:dark)').addEventListener('change',function(){
if((localStorage.getItem(k)||'system')==='system')document.documentElement.setAttribute('data-theme',resolve('system'));
});
applyStored();
}catch(e){}
})();
</script>
</body>
</html>
